@model IEnumerable<ShopInternet.Models.Category>

@{
    ViewData["Title"] = "Список категорій";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Список категорій</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> &nbsp; Створити нову категорію
            </a>
        </div>
    </div>

    <br /><br />

    <table class="table table-hover table-bordered table-striped" style="width:100%">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Order)
                </th>
                <th class="text-center">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td width="50%">
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td width="30%">
                        @Html.DisplayFor(modelItem => item.Order)
                    </td>
                    <td class="text-center">
                        <div class="w-75 btn-group" role="group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil-square"></i> Редагувати
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger mx-2">
                                <i class="bi bi-trash-fill"></i> Видалити
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
