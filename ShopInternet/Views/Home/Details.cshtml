@model ShopInternet.Models.ViewModels.DetailsVM

@{
    ViewData["Title"] = "Деталі товару";
}

<div class="container pt-4">
    <div class="card shadow border-0 mt-4">
        <div class="card-header bg-dark bg-gradient text-light py-3">
            <div class="row">
                <div class="col-12 text-center">
                    <h3 class="text-white py-2">@Model.Product.Name</h3>
                </div>
            </div>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-12 col-lg-4 text-center mb-3">
                    @if (!string.IsNullOrEmpty(Model.Product.Image))
                    {
                        <img src="@(WC.ImagePath + Model.Product.Image)" class="img-fluid rounded shadow" style="width: 100%; object-fit: cover;" alt="@Model.Product.Name" />
                    }
                    else
                    {
                        <img src="https://placehold.co/400x400/png?text=Немає+фото" class="img-fluid rounded shadow" style="width: 100%;" alt="Немає фото" />
                    }
                </div>
                <div class="col-12 col-lg-8">
                    <form method="post">
                        <input asp-for="Product.Id" hidden />
                        <div class="row ps-2">
                            <div class="col-12 border-bottom pb-3">
                                <h4 class="text-primary fw-bold">@Model.Product.Name</h4>
                            </div>
                            <div class="col-12 pt-3">
                                <p class="text-dark"><strong>Опис: </strong>@Html.Raw(Model.Product.Description)</p>
                            </div>
                            <div class="col-12">
                                <p class="text-dark"><strong>Ціна: </strong>@Model.Product.Price.ToString("c")</p>
                            </div>
                            <div class="col-12">
                                <p class="text-dark"><strong>Категорія: </strong>@(Model.Product.Category?.Name ?? "Без категорії")</p>
                            </div>
                            <div class="col-12">
                                <div class="row pt-2">
                                    <div class="col-4">
                                        Кількість:
                                    </div>
                                    <div class="col-8">
                                        @if (Model.ExistsInCart)
                                        {
                                            <input asp-for="Product.TempCount" class="form-control" readonly />
                                        }
                                        else
                                        {
                                            <input type="number" asp-for="Product.TempCount" class="form-control" min="1" />
                                            <span asp-validation-for="Product.TempCount" class="text-danger"></span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row pt-3">
                            <div class="col-12 col-md-6 pb-1">
                                <a asp-action="Index" class="btn btn-success btn-square form-control btn-lg" style="height:50px;">Назад</a>
                            </div>
                            <div class="col-12 col-md-6 pb-1">
                                @if (Model.ExistsInCart)
                                {
                                    <a asp-action="RemoveFromCart" asp-route-id="@Model.Product.Id" class="btn btn-warning btn-square form-control btn-lg" style="height:50px;">Видалити з кошика</a>
                                }
                                else
                                {
                                    <button type="submit" asp-route-id="@Model.Product.Id" class="btn btn-info form-control btn-lg" style="height:50px;">Додати в кошик</button>
                                }
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
