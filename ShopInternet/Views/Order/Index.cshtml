@using ShopInternet
@model IEnumerable<ShopInternet.Models.OrderHeader>

@{
    ViewData["Title"] = "Замовлення";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var statuses = new List<string> { WC.StatusInProgress, WC.StatusConfirmed, WC.StatusShipped };
}

<div class="container-fluid p-3">
    <div class="row pt-4">
        <div class="col-12">
            <h2 class="text-primary">Список замовлень</h2>
        </div>
    </div>

    <br />

    @if (!Model.Any())
    {
        <p>Замовлень ще немає.</p>
    }
    else
    {
        <table class="table table-hover table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>№</th>
                    <th>ПІБ</th>
                    <th>Телефон</th>
                    <th>Адреса доставки</th>
                    <th>Дата</th>
                    <th>Сума</th>
                    <th>Статус</th>
                    <th class="text-center">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.FullName</td>
                        <td>@order.PhoneNumber</td>
                        <td>@order.ShippingAddress</td>
                        <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@order.OrderTotal.ToString("0.00")</td>
                        <td>
                            <form method="post" asp-action="ChangeStatus" class="d-flex">
                                <input type="hidden" name="id" value="@order.Id" />
                                <select name="newStatus" class="form-select form-select-sm" onchange="this.form.submit()">
                                    @foreach (var status in statuses)
                                    {
                                        if (status == order.OrderStatus)
                                        {
                                            <option value="@status" selected>@status</option>
                                        }
                                        else
                                        {
                                            <option value="@status">@status</option>
                                        }
                                    }
                                </select>
                            </form>
                        </td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-primary btn-sm mx-1">
                                    Редагувати
                                </a>
                                <a asp-action="Delete" asp-route-id="@order.Id" class="btn btn-danger btn-sm mx-1">
                                    Видалити
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
