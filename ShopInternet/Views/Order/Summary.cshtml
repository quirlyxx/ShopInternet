@model ShopInternet.Models.ViewModels.ProductUserVM

<form method="post">
    <br />
    <div class="backgroundWhiteBorder">
        <div class="container">
            <div class="card">
                <div class="card-header bg-dark text-light ml-0 row container">
                    <div class="col-6">
                        <i class="fa fa-shopping-cart"></i> &nbsp;
                        Підсумок замовлення
                    </div>
                    <div class="col-6 text-end">
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-info btn-sm">Назад до кошика</a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="container rounded p-2">
                        <div class="row">
                            <div class="col-12 col-lg-7 pb-4">
                                <input asp-for="OrderHeader.Id" hidden />
                                <div class="row">
                                    <h4 class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-info">Деталі доставки:</span>
                                    </h4>
                                </div>
                                <div class="row my-1">
                                    <div class="col-3">
                                        <label>ПІБ</label>
                                    </div>
                                    <div class="col-9">
                                        <input asp-for="OrderHeader.FullName" type="text" class="form-control" />
                                        <span asp-validation-for="OrderHeader.FullName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="row my-1">
                                    <div class="col-3">
                                        <label>Телефон</label>
                                    </div>
                                    <div class="col-9">
                                        <input asp-for="OrderHeader.PhoneNumber" type="text" class="form-control" />
                                        <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="row my-1">
                                    <div class="col-3">
                                        <label>Адреса доставки</label>
                                    </div>
                                    <div class="col-9">
                                        <input asp-for="OrderHeader.ShippingAddress" type="text" class="form-control" />
                                        <span asp-validation-for="OrderHeader.ShippingAddress" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-5 row">
                                <div class="col-12">
                                    <h4 class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-info">Ваше замовлення:</span>
                                    </h4>
                                    <ul class="list-group mb-3">
                                        @{
                                            decimal orderTotal = 0;
                                        }
                                        @for (int i = 0; i < Model.ProductList.Count; i++)
                                        {
                                            <input type="hidden" asp-for="@Model.ProductList[i].Id" />
                                            <input type="hidden" asp-for="@Model.ProductList[i].Name" />
                                            <li class="list-group-item d-flex justify-content-between">
                                                <div>
                                                    <h6 class="my-0">@Model.ProductList[i].Name</h6>
                                                    <small class="text-muted">Ціна: @Model.ProductList[i].Price.ToString("c") x @Model.ProductList[i].TempCount</small>
                                                </div>
                                                <span class="text-muted">@((Model.ProductList[i].Price * Model.ProductList[i].TempCount).ToString("c"))</span>
                                            </li>
                                            orderTotal += (Model.ProductList[i].Price * Model.ProductList[i].TempCount);
                                        }
                                        <li class="list-group-item d-flex justify-content-between bg-light">
                                            <small class="text-info">Разом (грн)</small>
                                            <strong class="text-info">@orderTotal.ToString("c")</strong>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="row">
                        <div class="col-12 col-md-5 offset-md-7">
                            <button type="submit" class="btn btn-primary form-control">Підтвердити замовлення</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}