@model IEnumerable<UserVM>

@{
    ViewData["Title"] = "Керування користувачами";
}

<h1>@ViewData["Title"]</h1>

<table class="table">
    <thead>
        <tr>
            <th>Ім'я</th>
            <th>Email</th>
            <th>Ролі</th>
            <th>Статус</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@string.Join(", ", user.Roles)</td>
                <td>
                    @if (user.IsBlocked)
                    {
                        <span class="badge bg-danger">Заблокований</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Активний</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-info btn-sm">Деталі</a>
                    <a asp-action="ChangePassword" asp-route-id="@user.Id" class="btn btn-warning btn-sm">Пароль</a>
                    <a asp-action="AssignRole" asp-route-id="@user.Id" class="btn btn-primary btn-sm">Роль</a>
                    <form asp-action="ToggleBlock" asp-route-id="@user.Id" method="post" style="display:inline">
                        @if (user.IsBlocked)
                        {
                            <button type="submit" class="btn btn-success btn-sm">Розблокувати</button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-secondary btn-sm" onclick="return confirm('Заблокувати користувача?')">Заблокувати</button>
                        }
                    </form>
                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" style="display:inline">
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Ви впевнені?')">Видалити</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>