@model AssignRoleVM

@{
    ViewData["Title"] = "Призначити роль";
}

<h1>@ViewData["Title"] для @Model.UserName</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="AssignRole" method="post">
            <input type="hidden" asp-for="UserId" />
            <div class="form-group">
                <label asp-for="RoleName" class="control-label"></label>
                <select asp-for="RoleName" class="form-control" asp-items="@(new SelectList(ViewBag.Roles))">
                    <option value="">-- Оберіть роль --</option>
                </select>
                <span asp-validation-for="RoleName" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary">Зберегти</button>
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>