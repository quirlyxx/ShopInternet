@model UserVM

@{
    ViewData["Title"] = "Деталі користувача";
}

<h1>@ViewData["Title"]</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Ім'я</dt>
        <dd class="col-sm-10">@Model.UserName</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Ролі</dt>
        <dd class="col-sm-10">@string.Join(", ", Model.Roles)</dd>
    </dl>
</div>
<div>
    <a asp-action="ChangePassword" asp-route-id="@Model.Id" class="btn btn-warning">Змінити пароль</a> |
    <a asp-action="Index" class="btn btn-secondary">Назад до списку</a>
</div>
